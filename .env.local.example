# GE-VIC local real-mode config
# Usage: copy to .env.local, fill in your real LLM key
#   cp .env.local.example .env.local
# Then: powershell -ExecutionPolicy Bypass -File scripts\start-app-real.ps1

# ---- Required: LLM API key ----
# DashScope (Aliyun, recommended, signup gives 2M free tokens)
#   Sign up: https://dashscope.console.aliyun.com
LLM_API_KEY=sk-your-dashscope-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Vision+text: qwen-vl-max, qwen-vl-plus (recommended), qwen-vl-ocr
# Text only: qwen-plus, qwen-turbo, qwen-max
LLM_MODEL=qwen-vl-plus

# ---- OpenAI ----
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- Ollama (local, free) ----
# Run ollama serve first, then: ollama pull llava
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llava

# ---- Advanced: split models for enrich vs vision (M0 not supported) ----
# LLM_MODEL_ENRICH=qwen-plus
# LLM_MODEL_VISION=qwen-vl-plus